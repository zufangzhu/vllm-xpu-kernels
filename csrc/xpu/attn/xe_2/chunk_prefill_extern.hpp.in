// LSE axis: both true and false (only valid when P=F,L=F,S=F)
#define DECLARE_FOR_LSE_BOTH(POLICY, PAGED, CAUSAL, LOCAL, SINK)            \
  DECLARE_POLICY_DISPATCH_EXTERN(POLICY, PAGED, CAUSAL, LOCAL, SINK, false) \
  DECLARE_POLICY_DISPATCH_EXTERN(POLICY, PAGED, CAUSAL, LOCAL, SINK, true)

// LSE axis: only false
#define DECLARE_FOR_LSE_FALSE(POLICY, PAGED, CAUSAL, LOCAL, SINK) \
  DECLARE_POLICY_DISPATCH_EXTERN(POLICY, PAGED, CAUSAL, LOCAL, SINK, false)

// Sink axis (for unconstrained P/L/S tree -> LSE=false only)
#define DECLARE_FOR_SINK_FALSEONLY(POLICY, PAGED, CAUSAL, LOCAL) \
  DECLARE_FOR_LSE_FALSE(POLICY, PAGED, CAUSAL, LOCAL, false)     \
  DECLARE_FOR_LSE_FALSE(POLICY, PAGED, CAUSAL, LOCAL, true)

#define DECLARE_FOR_LOCAL_FALSEONLY(POLICY, PAGED, CAUSAL) \
